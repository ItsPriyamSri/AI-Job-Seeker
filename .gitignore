# =============================================================================
# AI Job Seeker — Monorepo .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# -----------------------------------------------------------------------------
# Environment & Secrets — NEVER commit these
# -----------------------------------------------------------------------------
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging
*.pem
*.key
*.p12
*.pfx

# -----------------------------------------------------------------------------
# Build Outputs
# -----------------------------------------------------------------------------
dist/
build/
out/
.output/

# Client (Vite)
client/dist/
client/.vite/

# Server (compiled TypeScript)
server/dist/

# -----------------------------------------------------------------------------
# TypeScript
# -----------------------------------------------------------------------------
*.tsbuildinfo
*.d.ts.map

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# -----------------------------------------------------------------------------
# Runtime & Cache
# -----------------------------------------------------------------------------
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
.tsc-cache/

# Vite cache
.vite/

# TanStack Query devtools build cache
.tanstack/

# -----------------------------------------------------------------------------
# OS & Editor artifacts
# -----------------------------------------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptionKey
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json

# JetBrains IDEs
.idea/
*.iml
*.iws
*.ipr

# Vim / Neovim
*.swp
*.swo
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
Session.vim
Neovim swap files

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
*.lcov
playwright-report/
test-results/

# -----------------------------------------------------------------------------
# Package managers
# -----------------------------------------------------------------------------
.npm/
.pnpm-store/
package-lock.json.bak

# -----------------------------------------------------------------------------
# Uploads & generated files (local dev only)
# -----------------------------------------------------------------------------
uploads/
server/uploads/
*.pdf
!sample-resume.pdf

# Cloudinary temp files
.cloudinary/

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
*.orig
*.bak
*.tmp
*.temp
.vercel
.netlify
